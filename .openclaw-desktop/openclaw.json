{
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://127.0.0.1:11434",
        "apiKey": "ollama-local",
        "auth": "api-key",
        "api": "ollama",
        "models": [
          {
            "id": "qwen-hakua-core",
            "name": "Hakua Core (ASI Uncensored)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 8192
          },
          {
            "id": "qwen3.5:9b",
            "name": "Qwen 3.5 9B (GPU)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 262144,
            "maxTokens": 8192
          },
          {
            "id": "qwen3:4b-thinking-2507-q4_K_M",
            "name": "Qwen3 4B Thinking",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 262144,
            "maxTokens": 16384,
            "compat": {
              "thinkingFormat": "qwen"
            }
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/qwen-hakua-core",
        "fallbacks": ["ollama/qwen3.5:9b", "openai-codex/gpt-5.4"]
      },
      "timeoutSeconds": 900,
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "line": {
      "enabled": true,
      "channelAccessToken": "${LINE_CHANNEL_ACCESS_TOKEN}",
      "channelSecret": "${LINE_CHANNEL_SECRET}",
      "webhookPath": "${LINE_WEBHOOK_PATH}",
      "webhookServerUrl": "${LINE_WEBHOOK_URL}",
      "dmPolicy": "${LINE_DM_POLICY}",
      "groupPolicy": "open",
      "groupAllowFrom": ["*"],
      "allowFrom": ["*"],
      "groups": {
        "*": {
          "requireMention": false
        }
      }
    },
    "telegram": {
      "enabled": false,
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "streaming": "partial"
    },
    "discord": {
      "enabled": true,
      "groupPolicy": "allowlist",
      "streaming": "off"
    },
    "slack": {
      "mode": "socket",
      "webhookPath": "/slack/events",
      "enabled": true,
      "userTokenReadOnly": true,
      "groupPolicy": "allowlist",
      "nativeStreaming": true,
      "streaming": "partial"
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.3.8",
    "lastTouchedAt": "2026-03-08T12:35:00.000Z"
  }
}
