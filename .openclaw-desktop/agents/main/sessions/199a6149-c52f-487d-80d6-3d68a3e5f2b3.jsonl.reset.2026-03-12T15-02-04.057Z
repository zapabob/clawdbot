mal\"', '\"low\"', '\"medium\"', '\"high\"'],\nsrc/config/schema.help.quality.test.ts:441:  \"hooks.gmail.account\",\nsrc/config/schema.help.quality.test.ts:442:  \"hooks.gmail.allowUnsafeExternalContent\",\nsrc/config/schema.help.quality.test.ts:443:  \"hooks.gmail.hookUrl\",\nsrc/config/schema.help.quality.test.ts:444:  \"hooks.gmail.includeBody\",\nsrc/config/schema.help.quality.test.ts:445:  \"hooks.gmail.label\",\nsrc/config/schema.help.quality.test.ts:446:  \"hooks.gmail.model\",\nsrc/config/schema.help.quality.test.ts:447:  \"hooks.gmail.serve\",\nsrc/config/schema.help.quality.test.ts:448:  \"hooks.gmail.subscription\",\nsrc/config/schema.help.quality.test.ts:449:  \"hooks.gmail.tailscale\",\nsrc/config/schema.help.quality.test.ts:450:  \"hooks.gmail.topic\",\nsrc/config/schema.help.quality.test.ts:451:  \"hooks.internal.entries\",\nsrc/config/schema.help.quality.test.ts:452:  \"hooks.internal.installs\",\nsrc/config/schema.help.quality.test.ts:453:  \"hooks.internal.load\",\nsrc/config/schema.help.quality.test.ts:454:  \"hooks.mappings[].allowUnsafeExternalContent\",\nsrc/config/schema.help.quality.test.ts:455:  \"hooks.mappings[].deliver\",\nsrc/config/schema.help.quality.test.ts:456:  \"hooks.mappings[].id\",\nsrc/config/schema.help.quality.test.ts:457:  \"hooks.mappings[].match\",\nsrc/config/schema.help.quality.test.ts:458:  \"hooks.mappings[].messageTemplate\",\nsrc/config/schema.help.quality.test.ts:459:  \"hooks.mappings[].model\",\nsrc/config/schema.help.quality.test.ts:460:  \"hooks.mappings[].name\",\nsrc/config/schema.help.quality.test.ts:461:  \"hooks.mappings[].textTemplate\",\nsrc/config/schema.help.quality.test.ts:462:  \"hooks.mappings[].thinking\",\nsrc/config/schema.help.quality.test.ts:463:  \"hooks.mappings[].transform\",\nsrc/config/schema.help.quality.test.ts:602:  it(\"covers tools/hooks help keys with non-trivial operational guidance\", () => {\nsrc/config/schema.help.quality.test.ts:742:    const transformModule = FIELD_HELP[\"hooks.mappings[].transform.module\"];\nsrc/config/schema.help.quality.test.ts:777:    const pluginPromptPolicy = FIELD_HELP[\"plugins.entries.*.hooks.allowPromptInjection\"];\nsrc/config/schema.help.ts:49:    'Console output format style: \"pretty\", \"compact\", or \"json\" based on operator and ingestion needs. Use json for machine parsing pipelines and pretty/compact for human-first terminal workflows.',\nsrc/config/schema.help.ts:88:    \"Allows trusted Tailscale identity paths to satisfy gateway auth checks when configured. Use this only when your tailnet identity posture is strong and operator workflows depend on it.\",\nsrc/config/schema.help.ts:208:    \"Agent runtime configuration root covering defaults and explicit agent entries used for routing and execution context. Keep this section explicit so model/tool behavior stays predictable across multi-agent workflows.\",\nsrc/config/schema.help.ts:234:    \"Browser runtime controls for local or remote CDP attachment, profile routing, and screenshot/snapshot behavior. Keep defaults unless your automation workflow requires custom browser transport settings.\",\nsrc/config/schema.help.ts:236:    \"Enables browser capability wiring in the gateway so browser tools and CDP-driven workflows can run. Disable when browser automation is not needed to reduce surface area and startup work.\",\nsrc/config/schema.help.ts:268:    \"Enables browser-side evaluate helpers for runtime script evaluation capabilities where supported. Keep disabled unless your workflows require evaluate semantics beyond snapshots/navigation.\",\nsrc/config/schema.help.ts:272:    \"Default snapshot extraction mode controlling how page content is transformed for agent consumption. Choose the mode that balances readability, fidelity, and token footprint for your workflows.\",\nsrc/config/schema.help.ts:310:    \"Execution security posture selector controlling sandbox/approval expectations for command execution. Keep strict security mode for untrusted prompts and relax only for trusted operator workflows.\",\nsrc/config/schema.help.ts:322:    \"Elevated tool access controls for privileged command surfaces that should only be reachable from trusted senders. Keep disabled unless operator workflows explicitly require elevated actions.\",\nsrc/config/schema.help.ts:330:    \"Allow/deny tool policy applied to spawned subagent runtimes for per-subagent hardening. Keep this narrower than parent scope when subagents run semi-autonomous workflows.\",\nsrc/config/schema.help.ts:353:    \"Canvas host settings for serving canvas assets and local live-reload behavior used by canvas-enabled workflows. Keep disabled unless canvas-hosted assets are actively used.\",\nsrc/config/schema.help.ts:355:    \"Enables the canvas host server process and routes for serving canvas files. Keep disabled when canvas workflows are inactive to reduce exposed local services.\",\nsrc/config/schema.help.ts:361:    \"Enables automatic live-reload behavior for canvas assets during development workflows. Keep disabled in production-like environments where deterministic output is preferred.\",\nsrc/config/schema.help.ts:424:    \"Groups browser-proxy settings for exposing local browser control through node routing. Enable only when remote node workflows need your local browser profiles.\",\nsrc/config/schema.help.ts:583:    \"Timeout in seconds for each image understanding request before it is aborted. Increase for high-resolution analysis and lower it for latency-sensitive operator workflows.\",\nsrc/config/schema.help.ts:606:    \"Scope selector controlling when video understanding is attempted across incoming events. Narrow scope in noisy channels, and broaden only where video interpretation is core to workflow.\",\nsrc/config/schema.help.ts:608:    \"Enable filesystem watching for skill-definition changes so updates can be applied without full process restart. Keep enabled in development workflows and disable in immutable production images.\",\nsrc/config/schema.help.ts:618:    'Controls where approval prompts are sent: \"session\" uses origin chat, \"targets\" uses configured targets, and \"both\" sends to both paths. Use \"session\" as baseline and expand only when operational workflow requires redundancy.',\nsrc/config/schema.help.ts:944:  \"plugins.entries.*.hooks\":\nsrc/config/schema.help.ts:946:  \"plugins.entries.*.hooks.allowPromptInjection\":\nsrc/config/schema.help.ts:947:    \"Controls whether this plugin may mutate prompts through typed hooks. Set false to block `before_prompt_build` and ignore prompt-mutating fields from legacy `before_agent_start`, while preserving legacy `modelOverride` and `providerOverride` behavior.\",\nsrc/config/schema.help.ts:1042:    \"Registers native slash/menu commands with channels that support command registration (Discord, Slack, Telegram). Keep enabled for discoverability unless you intentionally run text-only command workflows.\",\nsrc/config/schema.help.ts:1092:    \"Defines reset policy for thread-scoped sessions, including focused channel thread workflows. Use this when thread sessions should expire faster or slower than other chat types.\",\nsrc/config/schema.help.ts:1128:    \"Shared defaults for thread-bound session routing behavior across providers that support thread focus workflows. Configure global defaults here and override per channel only when behavior differs.\",\nsrc/config/schema.help.ts:1130:    \"Global master switch for thread-bound session routing features and focused thread delivery behavior. Keep enabled for modern thread workflows unless you need to disable thread binding globally.\",\nsrc/config/schema.help.ts:1180:  hooks:\nsrc/config/schema.help.ts:1182:  \"hooks.enabled\":\nsrc/config/schema.help.ts:1183:    \"Enables the hooks endpoint and mapping execution pipeline for inbound webhook requests. Keep disabled unless you are actively routing external events into the gateway.\",\nsrc/config/schema.help.ts:1184:  \"hooks.path\":\nsrc/config/schema.help.ts:1185:    \"HTTP path used by the hooks endpoint (for example `/hooks`) on the gateway control server. Use a non-guessable path and combine it with token validation for defense in depth.\",\nsrc/config/schema.help.ts:1186:  \"hooks.token\":\nsrc/config/schema.help.ts:1187:    \"Shared bearer token checked by hooks ingress for request authentication before mappings run. Use environment substitution and rotate regularly when webhook endpoints are internet-accessible.\",\nsrc/config/schema.help.ts:1188:  \"hooks.defaultSessionKey\":\nsrc/config/schema.help.ts:1190:  \"hooks.allowRequestSessionKey\":\nsrc/config/schema.help.ts:1192:  \"hooks.allowedSessionKeyPrefixes\":\nsrc/config/schema.help.ts:1193:    \"Allowlist of accepted session-key prefixes for inbound hook requests when caller-provided keys are enabled. Use narrow prefixes to prevent arbitrary session-key injection.\",\nsrc/config/schema.help.ts:1194:  \"hooks.allowedAgentIds\":\nsrc/config/schema.help.ts:1196:  \"hooks.maxBodyBytes\":\nsrc/config/schema.help.ts:1198:  \"hooks.presets\":\nsrc/config/schema.help.ts:1200:  \"hooks.transformsDir\":\nsrc/config/schema.help.ts:1202:  \"hooks.mappings\":\nsrc/config/schema.help.ts:1203:    \"Ordered mapping rules that match inbound hook requests and choose wake or agent actions with optional delivery routing. Use specific mappings first to avoid broad pattern rules capturing everything.\",\nsrc/config/schema.help.ts:1204:  \"hooks.mappings[].id\":\nsrc/config/schema.help.ts:1206:  \"hooks.mappings[].match\":\nsrc/config/schema.help.ts:1208:  \"hooks.mappings[].match.path\":\nsrc/config/schema.help.ts:1210:  \"hooks.mappings[].match.source\":\nsrc/config/schema.help.ts:1212:  \"hooks.mappings[].action\":\nsrc/config/schema.help.ts:1214:  \"hooks.mappings[].wakeMode\":\nsrc/config/schema.help.ts:1216:  \"hooks.mappings[].name\":\nsrc/config/schema.help.ts:1218:  \"hooks.mappings[].agentId\":\nsrc/config/schema.help.ts:1220:  \"hooks.mappings[].sessionKey\":\nsrc/config/schema.help.ts:1222:  \"hooks.mappings[].messageTemplate\":\nsrc/config/schema.help.ts:1224:  \"hooks.mappings[].textTemplate\":\nsrc/config/schema.help.ts:1226:  \"hooks.mappings[].deliver\":\nsrc/config/schema.help.ts:1228:  \"hooks.mappings[].allowUnsafeExternalContent\":\nsrc/config/schema.help.ts:1230:  \"hooks.mappings[].channel\":\nsrc/config/schema.help.ts:1232:  \"hooks.mappings[].to\":\nsrc/config/schema.help.ts:1234:  \"hooks.mappings[].model\":\nsrc/config/schema.help.ts:1236:  \"hooks.mappings[].thinking\":\nsrc/config/schema.help.ts:1237:    \"Optional thinking-effort override for mapping-triggered runs to tune latency versus reasoning depth. Keep low or minimal for high-volume hooks unless deeper reasoning is clearly required.\",\nsrc/config/schema.help.ts:1238:  \"hooks.mappings[].timeoutSeconds\":\nsrc/config/schema.help.ts:1240:  \"hooks.mappings[].transform\":\nsrc/config/schema.help.ts:1242:  \"hooks.mappings[].transform.module\":\nsrc/config/schema.help.ts:1243:    \"Relative transform module path loaded from hooks.transformsDir to rewrite incoming payloads before delivery. Keep modules local, reviewed, and free of path traversal patterns.\",\nsrc/config/schema.help.ts:1244:  \"hooks.mappings[].transform.export\":\nsrc/config/schema.help.ts:1246:  \"hooks.gmail\":\nsrc/config/schema.help.ts:1248:  \"hooks.gmail.account\":\nsrc/config/schema.help.ts:1250:  \"hooks.gmail.label\":\nsrc/config/schema.help.ts:1252:  \"hooks.gmail.topic\":\nsrc/config/schema.help.ts:1254:  \"hooks.gmail.subscription\":\nsrc/config/schema.help.ts:1256:  \"hooks.gmail.hookUrl\":\nsrc/config/schema.help.ts:1258:  \"hooks.gmail.includeBody\":\nsrc/config/schema.help.ts:1260:  \"hooks.gmail.allowUnsafeExternalContent\":\nsrc/config/schema.help.ts:1262:  \"hooks.gmail.serve\":\nsrc/config/schema.help.ts:1264:  \"hooks.gmail.pushToken\":\nsrc/config/schema.help.ts:1266:  \"hooks.gmail.maxBytes\":\nsrc/config/schema.help.ts:1268:  \"hooks.gmail.renewEveryMinut