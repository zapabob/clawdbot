{
  "channels": {
    "line": {
      "enabled": true,
      "channelAccessToken": "${LINE_CHANNEL_ACCESS_TOKEN}",
      "channelSecret": "${LINE_CHANNEL_SECRET}",
      "dmPolicy": "open",
      "groupPolicy": "allowlist"
    }
  },
  "skills": {
    "entries": {
      "codex": {
        "enabled": true,
        "env": {
          "OPENAI_API_KEY": "${OPENAI_API_KEY}"
        }
      },
      "gemini": {
        "enabled": true,
        "env": {
          "GEMINI_API_KEY": "${GEMINI_API_KEY}"
        }
      },
      "opencode": {
        "enabled": true
      }
    }
  },
  "gateway": {
    "tailscale": {
      "mode": "serve"
    }
  }
}
