# ============================================
# 🦞 OpenClaw Environment Variables Template
# ============================================
# Copy to .env and fill with your credentials
# DO NOT commit .env to version control!

# ============================================
# 🔐 CORE SECURITY
# ============================================
NODE_ENV=development
ENCRYPTION_KEY=
JWT_SECRET=
SESSION_SECRET=

# ============================================
# 📞 LINE MESSAGING API (Required)
# ============================================
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_WEBHOOK_PATH=/line/webhook
LINE_DM_POLICY=open
LINE_GROUP_POLICY=allowlist

# ============================================
# 🤖 AI TOOLS - OpenAI Codex
# ============================================
OPENAI_API_KEY=
OPENAI_CLIENT_ID=
OPENAI_CLIENT_SECRET=
CODEX_ENABLED=true
CODEX_MODEL=codex-5.1-max

# ============================================
# 🤖 AI TOOLS - Google Gemini CLI
# ============================================
GEMINI_API_KEY=
GEMINI_CLIENT_ID=
GEMINI_CLIENT_SECRET=
GEMINI_CLI_AUTH=
GEMINI_CLI_ENABLED=true

# ============================================
# 🤖 AI TOOLS - Opencode
# ============================================
OPENCODE_API_KEY=
OPENCODE_ENABLED=true

# ============================================
# 🧠 DEFAULT AI MODEL
# ============================================
DEFAULT_AI_MODEL=gpt-4
DEFAULT_AI_PROVIDER=openai
PRIMARY_MODEL=openai/gpt-4
FALLBACK_MODEL=openai/codex-5.1-max

# ============================================
# 📱 MESSAGING PLATFORMS - WhatsApp
# ============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ============================================
# 📱 MESSAGING PLATFORMS - Discord
# ============================================
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# ============================================
# 📱 MESSAGING PLATFORMS - Slack
# ============================================
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ============================================
# 📱 MESSAGING PLATFORMS - Telegram
# ============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ============================================
# 🎮 VRCHAT
# ============================================
VRCHAT_USERNAME=
VRCHAT_PASSWORD=
VRCHAT_2FA_SECRET=
VRCHAT_2FA_METHOD=totp
VRCHAT_OSC_RECEIVE_PORT=9001
VRCHAT_OSC_SEND_PORT=9000
VRCHAT_OSC_HOST=127.0.0.1
VRCHAT_PERMISSION_PROFILE=SAFE
VRCHAT_WORLD_ID=

# ============================================
# 🌐 NETWORK & WEBHOOK
# ============================================
CLAWDBOT_GATEWAY_PORT=3000
CLAWDBOT_GATEWAY_BIND=loopback
CLAWDBOT_GATEWAY_MODE=local
WEBHOOK_BASE_URL=
NGROK_AUTH_TOKEN=
NGROK_REGION=jp

# ============================================
# 🌐 TAILSCALE
# ============================================
CLAWDBOT_USE_TAILSCALE=false
TAILSCALE_FUNNEL_PORT=18789

# ============================================
# 🗄️ DATABASE
# ============================================
DATABASE_URL=
REDIS_URL=

# ============================================
# 💾 MEMORY SYSTEM
# ============================================
MEMORY_LANCEDB_PATH=%USERPROFILE%\.openclaw\memory\lancedb
MEMORY_MAX_ENTRIES=10000
MEMORY_EXPIRY_DAYS=365

# ============================================
# 📁 PATHS & DIRECTORIES
# ============================================
CLAWDBOT_WORKSPACE_DIR=%USERPROFILE%\.openclaw\workspace
CLAWDBOT_STATE_DIR=%USERPROFILE%\.openclaw
CLAWDBOT_CONFIG_PATH=%USERPROFILE%\.openclaw\config.json
CLAWDBOT_LOG_DIR=%USERPROFILE%\.openclaw\logs

# ============================================
# ⚙️ AUTO-IMPROVE SYSTEM
# ============================================
AUTO_IMPROVE_ENABLED=true
AUTO_IMPROVE_MODE=high
AUTO_IMPROVE_CHECK_INTERVAL=30
AUTO_IMPROVE_SELF_HEALING=true
AUTO_IMPROVE_AUTO_ROLLBACK=true
AUTO_IMPROVE_MAX_FILES_PER_BATCH=50

# ============================================
# 🔧 AUTO-AGENT SETTINGS
# ============================================
ENABLE_AUTO_IMPROVE=true
ENABLE_AUTO_REPAIR=true
ENABLE_GIT_AUTO_COMMIT=false
AUTO_AGENT_CHECK_INTERVAL_MS=60000
MAX_CHANGES_PER_COMMIT=10

# ============================================
# 📊 FREE TIER TRACKING
# ============================================
FREE_TIER_CODEX_LIMIT=100
FREE_TIER_GEMINI_LIMIT=50
FREE_TIER_OPENCODE_LIMIT=75

# ============================================
# 🚦 RATE LIMITS
# ============================================
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# 🔒 SECURITY
# ============================================
SECURITY_ALLOW_INSECURE=false
SECURITY_REQUIRE_DEVICE_AUTH=true

# ============================================
# 📝 LOGGING & DEBUGGING
# ============================================
LOG_LEVEL=info
DEBUG_MODE=false
LOG_AUTO_IMPROVE=true

# ============================================
# 📊 MONITORING & METRICS
# ============================================
MONITOR_INTERVAL_SECONDS=10
METRICS_ENABLED=true
HEALTH_CHECK_ENABLED=true

# ============================================
# 🔌 PLUGINS
# ============================================
PLUGINS_ENABLED=line,vrchat-relay
PLUGINS_DISABLED=

# ============================================
# 🌐 PROXY
# ============================================
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# ============================================
# 📧 NOTIFICATIONS
# ============================================
NOTIFICATION_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ============================================
# 🧪 TESTING (Do not modify)
# ============================================
CLAWDBOT_NO_ONBOARD=1
CLAWDBOT_INSTALL_SMOKE_SKIP_CLI=1
CLAWDBOT_INSTALL_SMOKE_SKIP_NONROOT=0
CLAWDBOT_INSTALL_SMOKE_SKIP_PREVIOUS=1

# ============================================
# 🏷️ FEATURE FLAGS
# ============================================
ENABLE_TELEMETRY=false
ENABLE_ANALYTICS=false
