# Copy to .env and fill with your credentials

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+17343367101

# VRChat Authentication
VRCHAT_USERNAME=your_username
VRCHAT_PASSWORD=your_password
# TOTP Secret for 2FA (from Authenticator app setup)
# Format: Base32 string (e.g., "JBSWY3DPEHPK3PXP")
# Get this when setting up 2FA in VRChat, or from your authenticator app settings
# VRCHAT_2FA_SECRET=YOUR_SECRET_KEY_HERE
# Optional: 2FA method (totp or email). Default: totp
# VRCHAT_2FA_METHOD=totp

# VRChat OSC Settings
VRCHAT_OSC_RECEIVE_PORT=9001
VRCHAT_OSC_SEND_PORT=9000
VRCHAT_OSC_HOST=127.0.0.1
VRCHAT_PERMISSION_PROFILE=SAFE

# Copy to .env and fill with your Twilio credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Must be a WhatsApp-enabled Twilio number, prefixed with whatsapp:
TWILIO_WHATSAPP_FROM=whatsapp:+17343367101
