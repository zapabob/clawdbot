{
  "channels": {
    "line": {
      "enabled": true,
      "channelAccessToken": "${LINE_CHANNEL_ACCESS_TOKEN}",
      "channelSecret": "${LINE_CHANNEL_SECRET}",
      "dmPolicy": "open",
      "groupPolicy": "allowlist"
    }
  },
  "skills": {
    "entries": {
      "codex": {
        "enabled": true,
        "env": {
          "OPENAI_CLIENT_ID": "${OPENAI_CLIENT_ID}",
          "OPENAI_CLIENT_SECRET": "${OPENAI_CLIENT_SECRET}",
          "OPENAI_API_KEY": "${OPENAI_API_KEY}"
        }
      },
      "gemini": {
        "enabled": true,
        "env": {
          "GEMINI_CLIENT_ID": "${GEMINI_CLIENT_ID}",
          "GEMINI_CLIENT_SECRET": "${GEMINI_CLIENT_SECRET}",
          "GEMINI_CLI_AUTH": "${GEMINI_CLI_AUTH}"
        }
      },
      "opencode": {
        "enabled": true
      },
      "moltbook": {
        "enabled": true,
        "env": {
          "MOLTBOOK_API_URL": "${MOLTBOOK_API_URL:-http://localhost:3000}",
          "MOLTBOOK_API_KEY": "${MOLTBOOK_API_KEY}"
        }
      }
    }
  },
  "gateway": {
    "tailscale": {
      "mode": "serve"
    }
  }
}
