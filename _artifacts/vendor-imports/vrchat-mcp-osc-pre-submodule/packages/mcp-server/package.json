{
  "name": "@vrchat-mcp-osc/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for vrchat-mcp-osc",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "vrchat-mcp-osc": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/server.js || echo 'chmod skipped (Windows environment)'",
    "start": "node dist/server.js",
    "dev": "ts-node --esm src/server.ts",
    "clean": "rimraf dist",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "vrchat",
    "osc",
    "mcp"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.7.0",
    "@vrchat-mcp-osc/types": "workspace:*",
    "@vrchat-mcp-osc/utils": "workspace:*",
    "@vrchat-mcp-osc/relay-server": "workspace:*",
    "node-osc": "^8.0.12",
    "uuid": "^9.0.1",
    "ws": "^8.15.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/node-osc": "^6.0.3",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "eslint": "^9.20.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}