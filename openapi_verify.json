  "components": {
    "schemas": {
      "CurriculumBuildRequest": {
        "properties": {
          "arxiv_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Arxiv Ids",
            "default": []
          },
          "include_soul": {
            "type": "boolean",
            "title": "Include Soul",
            "default": true
          },
          "extra_jsonl": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Extra Jsonl",
            "default": []
          }
        },
        "type": "object",
        "title": "CurriculumBuildRequest"
      },
      "EvolveRequest": {
        "properties": {
          "target": {
            "type": "string",
            "title": "Target"
          },
          "seed": {
            "type": "string",
            "title": "Seed"
          },
          "fitness_hint": {
            "type": "string",
            "title": "Fitness Hint",
            "default": ""
          },
          "generations": {
            "type": "integer",
            "title": "Generations",
            "default": 5
          }
        },
        "type": "object",
        "required": ["target", "seed"],
        "title": "EvolveRequest"
      },
      "GrpoJobRequest": {
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["placeholder", "train"],
            "title": "Mode",
            "default": "placeholder"
          },
          "dataset_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Dataset Path"
          }
        },
        "type": "object",
        "title": "GrpoJobRequest"
      },
      "GrpoPlaceholderRequest": {
        "properties": {
          "dataset_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Dataset Path"
          }
        },
        "type": "object",
        "title": "GrpoPlaceholderRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LoraTrainRequest": {
        "properties": {
          "dry_run": {
            "type": "boolean",
            "title": "Dry Run",
            "default": true
          },
          "dataset_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Dataset Path"
          }
        },
        "type": "object",
        "title": "LoraTrainRequest"
      },
      "OscRequest": {
        "properties": {
          "action": {
            "type": "string",
            "title": "Action"
          },
          "payload": {
            "additionalProperties": true,
            "type": "object",
            "title": "Payload",
            "default": {}
          }
        },
        "type": "object",
        "required": ["action"],
        "title": "OscRequest"
      },
      "RunRequest": {
        "properties": {
          "task": {
            "type": "string",
            "title": "Task"
          },
          "model": {
            "type": "string",
            "title": "Model",
            "default": "auto"
          },
          "max_retries": {
            "type": "integer",
            "title": "Max Retries",
            "default": 3
          }
        },
        "type": "object",
        "required": ["task"],
        "title": "RunRequest"
      },
      "ScavengeRequest": {
        "properties": {
          "query": {
            "type": "string",
            "title": "Query",
            "default": ""
          },
          "deep": {
            "type": "boolean",
            "title": "Deep",
            "default": false
          }
        },
        "type": "object",
        "title": "ScavengeRequest"
      },
      "SkillRequest": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "description": {
            "type": "string",
            "title": "Description"
          },
          "examples": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Examples",
            "default": []
          }
        },
        "type": "object",
        "required": ["name", "description"],
        "title": "SkillRequest"
      },
      "SpeakRequest": {
        "properties": {
          "text": {
            "type": "string",
            "title": "Text",
            "default": ""
          },
          "emotion": {
            "type": "string",
            "title": "Emotion",
            "default": "neutral"
          },
          "speaker": {
            "type": "integer",
            "title": "Speaker",
            "default": 8
          },
          "scene": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Scene",
            "default": []
          }
        },
        "type": "object",
        "title": "SpeakRequest"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": ["loc", "msg", "type"],
        "title": "ValidationError"
      },
      "WisdomRequest": {
        "properties": {
          "concept": {
            "type": "string",
            "title": "Concept"
          }
        },
        "type": "object",
        "required": ["concept"],
        "title": "WisdomRequest"
      }
    }
  }
