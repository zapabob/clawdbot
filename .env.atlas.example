# ATLAS / ShinkaEvolve / TinyLoRA local env template
#
# Usage:
#   Copy the values you want into `.env` or `.env.atlas`.
#   Example:
#     cat .env.atlas.example >> .env
#   Docker example:
#     docker compose --env-file .env.atlas up -d

# -----------------------------------------------------------------------------
# Model files
# -----------------------------------------------------------------------------

# Directory that contains your GGUF files.
MODELS_PATH=C:\Users\downl\Downloads

# Main model file for llama-service / ATLAS inference.
MAIN_MODEL_FILE=Qwen3.5-9B-Uncensored-HauhauCS-Aggressive-Q8_0.gguf

# Main model file for the OpenClaw llama.cpp provider.
LLAMA_CPP_MODEL=Gemma-4-E4B-Uncensored-HauhauCS-Aggressive-Q8_K_P.gguf

# Full GGUF path used by `pnpm llama-cpp:launch`.
LLAMA_CPP_MODEL_PATH=C:\Users\downl\Desktop\SO8T\gguf_models\HauhauCS\Gemma-4-E4B-Uncensored-HauhauCS-Aggressive\Gemma-4-E4B-Uncensored-HauhauCS-Aggressive-Q8_K_P.gguf

# Optional multimodal projector used by `pnpm llama-cpp:launch`.
LLAMA_CPP_MMPROJ_PATH=C:\Users\downl\Desktop\SO8T\gguf_models\HauhauCS\Gemma-4-E4B-Uncensored-HauhauCS-Aggressive\mmproj-Gemma-4-E4B-Uncensored-HauhauCS-Aggressive-f16.gguf

# API key or local marker for the llama.cpp OpenAI-compatible endpoint.
LLAMA_CPP_API_KEY=llama-cpp-local

# Base model used for TinyLoRA training.
HAKUA_CORE2_GGUF=Qwen3.5-9B-Uncensored-HauhauCS-Aggressive-Q4_K_M.gguf

# Optional draft model file.
DRAFT_MODEL_FILE=Qwen3-0.6B-Q8_0.gguf

# Hugging Face base model directory used by TinyLoRA.
HF_MODEL_DIR=C:\Users\downl\Downloads\hf\Qwen3.5-9B

# -----------------------------------------------------------------------------
# ATLAS / OpenClaw runtime
# -----------------------------------------------------------------------------

# Replace with a long random string before sharing or deploying.
JWT_SECRET=change-this-to-a-long-random-string

OPENCLAW_GATEWAY_TOKEN=change-me
OPENCLAW_CONFIG_DIR=./.openclaw-desktop
OPENCLAW_WORKSPACE_DIR=./workspace

# Context window for the inference stack.
CONTEXT_LENGTH=8192

# Train a LoRA after this many collected examples.
LORA_TRAINING_THRESHOLD=50

# Docker container name for llama-service, if your local setup needs it.
LORA_CONTAINER_NAME=clawdbot-main3-llama-service-1

# -----------------------------------------------------------------------------
# ShinkaEvolve -> llama-server connection
# -----------------------------------------------------------------------------

LLAMA_API_BASE=http://llama-service:8000/v1
LLAMA_MODEL_NAME=Qwen3.5-9B-Uncensored-HauhauCS-Aggressive-Q8_0.gguf
