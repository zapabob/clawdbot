# ATLAS × ShinkaEvolve × TinyLoRA — 環境変数テンプレート
# このファイルを .env にマージして使用してください
#   cat .env.atlas.example >> .env
# または .env.atlas として保存し docker compose に渡す:
#   docker compose --env-file .env.atlas up -d

# ── モデルファイル (必須) ─────────────────────────────────────────────────────

# GGUF モデルが置いてあるディレクトリ（絶対パス）
# qwen-Hakua-core2 の GGUF は Downloads に直接配置されている
MODELS_PATH=C:\Users\downl\Downloads

# メインモデルファイル名 (llama-service / ATLAS 推論用: Q8_0 高品質)
MAIN_MODEL_FILE=Qwen3.5-9B-Uncensored-HauhauCS-Aggressive-Q8_0.gguf

# qwen-Hakua-core2 ベースモデル (TinyLoRA 学習ターゲット: Q4_K_M)
HAKUA_CORE2_GGUF=Qwen3.5-9B-Uncensored-HauhauCS-Aggressive-Q4_K_M.gguf

# ドラフトモデルファイル名（投機デコード用）
DRAFT_MODEL_FILE=Qwen3-0.6B-Q8_0.gguf

# ── HuggingFace モデル (TinyLoRA 学習用、任意) ──────────────────────────────

# HF 形式の Qwen3.5-9B ディレクトリ（GGUF とは別に必要）
# TinyLoRA は 4-bit で ~5.7 GB → Q4_K_M 推論 (5.5 GB) より VRAM が少ない
# 学習を使わない場合は /tmp/hf-model のままで OK
HF_MODEL_DIR=C:\Users\downl\Downloads\hf\Qwen3.5-9B

# ── ATLAS 認証 (必須) ────────────────────────────────────────────────────────

# JWT 認証シークレット（任意の長い文字列）
JWT_SECRET=change-this-to-a-long-random-string

# ── Openclaw ────────────────────────────────────────────────────────────────

OPENCLAW_GATEWAY_TOKEN=change-me
OPENCLAW_CONFIG_DIR=./.openclaw-desktop
OPENCLAW_WORKSPACE_DIR=./workspace

# ── 推論設定 ─────────────────────────────────────────────────────────────────

# コンテキスト長 (RTX 3060 12GB では 8192 を推奨)
CONTEXT_LENGTH=8192

# ── TinyLoRA 継続学習 ────────────────────────────────────────────────────────

# この件数の学習例が溜まったら LoRA 学習を起動
LORA_TRAINING_THRESHOLD=50

# llama-service コンテナ名（docker compose ps で確認）
LORA_CONTAINER_NAME=clawdbot-main3-llama-service-1

# ── ShinkaEvolve → llama-server 接続 ────────────────────────────────────────

LLAMA_API_BASE=http://llama-service:8000/v1
LLAMA_MODEL_NAME=Qwen3.5-9B-Uncensored-HauhauCS-Aggressive-Q8_0.gguf
