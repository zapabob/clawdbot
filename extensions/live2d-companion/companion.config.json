{
  "avatarType": "auto",
  "avatarPath": "auto",
  "modelPath": "auto",
  "voicevoxSpeaker": 8,
  "voicevoxUrl": "http://127.0.0.1:50021",
  "ttsProvider": "voicevox",
  "webSpeechLang": "ja-JP",
  "webSpeechRate": 1.0,
  "webSpeechPitch": 1.1,
  "agentId": "main",
  "gatewayUrl": "http://127.0.0.1:18789",
  "controlPort": 18791,
  "stateDir": ".openclaw-desktop",
  "security": {
    "allowLegacyHttpControl": false,
    "allowLegacyFlagTransport": false
  },
  "browserHelper": {
    "enabled": true,
    "nativeHostName": "io.openclaw.desktop_companion",
    "persistentFollow": true
  },
  "assetPolicy": {
    "requireRightsAck": true,
    "importMode": "local-reference",
    "remoteUploadAllowed": false
  },
  "capturePolicy": {
    "mic": "deny-until-approved",
    "camera": "deny-until-approved",
    "screen": "deny-until-approved",
    "tab-follow": "deny-until-approved"
  },
  "window": {
    "width": 380,
    "height": 480,
    "offsetRight": 400,
    "offsetBottom": 500
  },
  "live2d": {
    "scale": 0.15,
    "anchorX": 0.5,
    "anchorY": 1.0,
    "positionX": 190,
    "positionY": 460
  },
  "stt": {
    "lang": "ja-JP",
    "continuous": true
  }
}
