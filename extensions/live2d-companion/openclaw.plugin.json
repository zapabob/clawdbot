{
  "id": "live2d-companion",
  "name": "Desktop Companion",
  "description": "Strict-local desktop companion overlay with VRM or FBX avatars, local whisper STT, VOICEVOX speech, and opt-in browser follow.",
  "version": "2026.4.17",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "description": "Enable the Desktop Companion integration.",
        "default": true
      },
      "llmMirror": {
        "type": "object",
        "description": "Mirror assistant output into the local Desktop Companion speech path.",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Enable local speech mirroring for assistant output.",
            "default": true
          },
          "maxChars": {
            "type": "integer",
            "description": "Maximum characters mirrored into local speech.",
            "default": 120
          }
        }
      },
      "security": {
        "type": "object",
        "properties": {
          "allowLegacyHttpControl": {
            "type": "boolean",
            "description": "Compatibility-only escape hatch for the legacy localhost control server.",
            "default": false
          },
          "allowLegacyFlagTransport": {
            "type": "boolean",
            "description": "Compatibility-only escape hatch for the legacy flag-file bridge.",
            "default": false
          }
        }
      },
      "browserHelper": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Enable the Desktop Companion browser helper integration.",
            "default": true
          },
          "nativeHostName": {
            "type": "string",
            "description": "Native Messaging host id used by the browser helper.",
            "default": "io.openclaw.desktop_companion"
          },
          "persistentFollow": {
            "type": "boolean",
            "description": "Keep following an explicitly attached tab until it is detached.",
            "default": true
          }
        }
      },
      "assetPolicy": {
        "type": "object",
        "properties": {
          "requireRightsAck": {
            "type": "boolean",
            "description": "Require explicit rights acknowledgment before importing avatar assets.",
            "default": true
          },
          "importMode": {
            "type": "string",
            "enum": ["local-reference", "local-copy"],
            "description": "How avatar assets are stored locally.",
            "default": "local-reference"
          },
          "remoteUploadAllowed": {
            "type": "boolean",
            "description": "Keep remote upload disabled in creator-safe local-only mode.",
            "default": false
          }
        }
      },
      "capturePolicy": {
        "type": "object",
        "properties": {
          "mic": {
            "type": "string",
            "enum": ["deny-until-approved", "granted"],
            "default": "deny-until-approved"
          },
          "camera": {
            "type": "string",
            "enum": ["deny-until-approved", "granted"],
            "default": "deny-until-approved"
          },
          "screen": {
            "type": "string",
            "enum": ["deny-until-approved", "granted"],
            "default": "deny-until-approved"
          },
          "tab-follow": {
            "type": "string",
            "enum": ["deny-until-approved", "granted"],
            "default": "deny-until-approved"
          }
        }
      },
      "voicevox": {
        "type": "object",
        "description": "VOICEVOX settings for the direct local speech fallback tool.",
        "properties": {
          "url": {
            "type": "string",
            "description": "Local VOICEVOX endpoint.",
            "default": "http://127.0.0.1:50021"
          },
          "speaker": {
            "type": "integer",
            "description": "VOICEVOX speaker id.",
            "default": 8
          }
        }
      }
    }
  }
}
